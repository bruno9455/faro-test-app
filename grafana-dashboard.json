{
  "dashboard": {
    "id": null,
    "uid": "faro-test-yarn-obs",
    "title": "Faro Test Yarn — Frontend Observability",
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 15,
    "refresh": "30s",
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "tags": [
      "faro",
      "frontend",
      "observability"
    ],
    "panels": [
      {
        "id": 1,
        "type": "geomap",
        "title": "🌍 Localização dos Utilizadores (por Cidade)",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 14,
          "h": 12
        },
        "datasource": {
          "type": "loki",
          "uid": "grafanacloud-logs"
        },
        "targets": [
          {
            "refId": "A",
            "expr": "sum by (geo_city) (count_over_time({service_name=\"faro-test-yarn\"} | logfmt | geo_city != \"\" [$__range]))",
            "queryType": "instant",
            "instant": true,
            "legendFormat": "{{geo_city}}"
          }
        ],
        "transformations": [
          {
            "id": "labelsToFields",
            "options": {
              "mode": "columns"
            }
          },
          {
            "id": "merge",
            "options": {}
          },
          {
            "id": "groupBy",
            "options": {
              "fields": {
                "geo_city": {
                  "operation": "groupby"
                },
                "Value": {
                  "operation": "aggregate",
                  "aggregations": [
                    "sum"
                  ]
                }
              }
            }
          },
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "Value (sum)": "Visitas"
              }
            }
          }
        ],
        "options": {
          "view": {
            "id": "zero",
            "lat": 30,
            "lon": 10,
            "zoom": 1.5
          },
          "controls": {
            "mouseWheelZoom": true,
            "showZoom": true,
            "showAttribution": true
          },
          "layers": [
            {
              "type": "markers",
              "name": "Cidades",
              "config": {
                "style": {
                  "color": {
                    "fixed": "orange"
                  },
                  "opacity": 0.85,
                  "size": {
                    "fixed": 8,
                    "max": 35,
                    "min": 5,
                    "field": "Visitas"
                  },
                  "symbol": {
                    "fixed": "img/icons/marker/circle.svg",
                    "mode": "fixed"
                  }
                },
                "showLegend": true
              },
              "location": {
                "mode": "lookup",
                "lookup": "geo_city",
                "gazetteer": "https://bruno9455.github.io/faro-test-app/cities.json"
              }
            }
          ],
          "tooltip": {
            "mode": "details"
          },
          "basemap": {
            "type": "default",
            "name": "Layer 0"
          }
        },
        "fieldConfig": {
          "defaults": {},
          "overrides": []
        }
      },
